{
  "name": "adhahi-dashboard-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Arabic Telegram Bot, Mini App, and dashboard for monitoring adhahi.dz registration.",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "nodemon server/src/index.js",
    "dev:client": "vite --host 0.0.0.0 --config client/vite.config.js",
    "start": "node server/src/index.js",
    "build": "vite build --config client/vite.config.js",
    "preview": "vite preview --host 0.0.0.0 --config client/vite.config.js",
    "postinstall": "playwright install chromium"
  },
  "dependencies": {
    "@playwright/test": "^1.52.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "axios": "^1.9.0",
    "compression": "^1.8.0",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "framer-motion": "^12.10.5",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "node-telegram-bot-api": "^0.66.0",
    "postcss": "^8.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "source-map-js": "^1.2.1",
    "tailwindcss": "^3.4.17",
    "uuid": "^11.1.0",
    "vite": "^6.3.5",
    "winston": "^3.17.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
